{
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "@tarquinen/opencode-dcp@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-token-monitor",
    "oh-my-openagent"
  ],
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "kotlin-ls": {
      "command": [
        "kotlin-lsp",
        "--stdio"
      ],
      "extensions": [
        ".kt",
        ".kts"
      ]
    },
    "jdtls": {
      "disabled": true
    }
  },
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--executablePath",
        "/usr/sbin/google-chrome-stable"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--enable-web-dashboard",
        "False"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "ddg-search": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server"
      ],
      "enabled": false
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": false
    }
  },
  "enabled_providers": [
    "openai"
  ]
}
