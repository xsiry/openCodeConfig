{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": false,
    "agents": false,
    "hooks": false,
    "plugins": false
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.2-codex",
      "prompt_append": "请始终使用简体中文进行回复，无论用户界面语言为何"
    },
    "oracle": {
      "model": "openai/gpt-5.2"
    },
    "librarian": {
      "model": "openai/gpt-5.2"
    },
    "explore": {
      "model": "openai/gpt-5.2"
    },
    "multimodal-looker": {
      "model": "google/gemini-3-flash-preview"
    },
    "prometheus": {
      "model": "openai/gpt-5.2-codex"
    },
    "metis": {
      "model": "openai/gpt-5.2-codex"
    },
    "momus": {
      "model": "openai/gpt-5.2-codex"
    },
    "atlas": {
      "model": "openai/gpt-5.2-codex"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3-pro-preview"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.2-codex"
    },
    "artistry": {
      "model": "google/gemini-3-pro-preview"
    },
    "quick": {
      "model": "openai/gpt-5.1-codex"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.2-codex"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.2-codex"
    },
    "writing": {
      "model": "google/gemini-3-flash-preview"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  }
}
